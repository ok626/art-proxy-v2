{
  "name": "stremio-artwork",
  "version": "1.0.0",
  "description": "Self-hosted artwork server for Stremio (AIOMetadata-compatible) with curated posters and deduplicated rotating backdrops",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-fetch": "^2.7.0",
    "sharp": "^0.33.5",
    "sharp-phash": "^2.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "@types/node-fetch": "^2.6.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
