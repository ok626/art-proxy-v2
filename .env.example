### ------------------------------------------------------------------------
### Server
### ------------------------------------------------------------------------
PORT=7777
# Base public URL this app is reachable at (used only for logging)
PUBLIC_URL=http://localhost:7777
# Where the sqlite db + on-disk hash cache live. Mount this as a volume.
DATA_DIR=/data
LOG_LEVEL=info
# Exposes GET /debug/backdrop/..., /debug/poster/..., and
# /debug/tvdb-artworks/... for inspecting pool state, cache metadata,
# and raw provider responses. On by default since this runs on your own
# server - set to false if you're exposing this beyond your own network.
DEBUG_ENDPOINTS_ENABLED=true

### ------------------------------------------------------------------------
### Provider credentials
### ------------------------------------------------------------------------
TMDB_API_KEY=your_tmdb_v3_api_key
# TVDB v4 API key (a "Project" API key from thetvdb.com/dashboard/account/apikeys)
TVDB_API_KEY=your_tvdb_v4_api_key
# Optional TVDB subscriber PIN, leave blank if you don't have one
TVDB_PIN=
# Free key from your MDBList account (mdblist.com/preferences) - powers
# the poster info bar's aggregated rating. Leave blank to disable the
# rating (genre will still show if POSTER_INFO_BAR_ENABLED=true).
MDBLIST_API_KEY=

### ------------------------------------------------------------------------
### Language / locale preferences
### ------------------------------------------------------------------------
# ISO 639-1 language you want artwork text/localization in
PRIMARY_LANGUAGE=en
# Two top-ranked posters are considered "tied" if their (Wilson-bound)
# score differs by less than this amount, in which case the one with
# more votes wins the tie.
VOTE_AVERAGE_TIE_THRESHOLD=0.30

### ------------------------------------------------------------------------
### Rating aggregation (powers the poster info bar's rating)
### ------------------------------------------------------------------------
# How much weight each rating source gets when combined into the single
# aggregated rating shown on posters. Format: "source:weight,...". These
# are relative to each other, not required to sum to 100 - if a source
# has no data for a given title, its weight is dropped and the rest are
# renormalized proportionally (e.g. "letterboxd:99,trakt:1" becomes 100%
# trakt if letterboxd is missing for that title). Valid source names (as
# returned by MDBList): imdb, tmdb, trakt, letterboxd, metacritic,
# tomatoes (Rotten Tomatoes critics), popcorn (RT audience), mal
# (MyAnimeList).
RATING_SOURCE_WEIGHTS=imdb:50,tmdb:30,trakt:20

### ------------------------------------------------------------------------
### Posters
### ------------------------------------------------------------------------
POSTER_MAIN_PROVIDER=tmdb
POSTER_BACKUP_PROVIDER=tvdb
# Ranking uses a Wilson score lower bound (same idea as Reddit/HN comment
# ranking) so a poster with a couple of lucky high votes doesn't out-rank
# one with dozens of votes at a slightly lower average. 1.96 = standard
# 95% confidence bound; higher = more skeptical of low vote counts.
POSTER_CONFIDENCE_Z=1.96

# --- Info bar: a dark bar across the bottom of the poster showing genre
# and/or an aggregated rating (and optionally year), plus a thin
# rating-progress strip above it. ---
POSTER_INFO_BAR_ENABLED=true
POSTER_INFO_BAR_SHOW_GENRE=true
POSTER_INFO_BAR_SHOW_RATING=true
POSTER_INFO_BAR_SHOW_YEAR=false
# Fraction of the poster's total height the bar takes up - measured
# directly from a reference app's screenshot, not guessed.
POSTER_INFO_BAR_HEIGHT_FRACTION=0.072
# Bar background opacity, 0-1.
POSTER_INFO_BAR_OPACITY=0.72
POSTER_INFO_BAR_BACKGROUND_COLOR=#101014
POSTER_INFO_BAR_TEXT_COLOR=#ffffff
# "100" shows the MDBList-style 0-100 score (e.g. "70"); "10" rescales it
# to a familiar 0-10-with-one-decimal look (e.g. "7.0").
POSTER_INFO_BAR_RATING_SCALE=100
# A thin strip directly above the bar, filled left-to-right proportional
# to rating/100 - like a slim progress/health bar. Only shown when a
# rating is actually available for the title.
POSTER_INFO_BAR_SHOW_PROGRESS_BAR=true
POSTER_INFO_BAR_PROGRESS_BAR_HEIGHT_FRACTION=0.0055
POSTER_INFO_BAR_PROGRESS_TRACK_COLOR=rgba(255,255,255,0.22)
POSTER_INFO_BAR_PROGRESS_FILL_COLOR=#ffffff

POSTER_OUTPUT_QUALITY=90
# Final poster dimensions - posters are resized to this BEFORE any
# styling is applied (smaller = faster generation + smaller files), and
# it's chosen to match what Stremio-like clients actually render
# (~0.675 aspect ratio). Change this if your client expects a different
# size.
POSTER_OUTPUT_WIDTH=580
POSTER_OUTPUT_HEIGHT=859
# Seconds the generated poster image may be cached by clients/CDNs
POSTER_CACHE_SECONDS=604800
# Days a *server-side* generated poster stays valid before a background
# refresh regenerates it. This is separate from POSTER_CACHE_SECONDS -
# it's what makes repeat requests (every future app launch) instant
# instead of re-running the whole selection+download+render pipeline.
POSTER_CACHE_REFRESH_DAYS=30

### ------------------------------------------------------------------------
### Backdrops
### ------------------------------------------------------------------------
BACKDROP_MAIN_PROVIDER=tmdb
BACKDROP_BACKUP_PROVIDER=tvdb
# main-backup: only query backup provider if main provider's *unique*
#              pool is below BACKDROP_MIN_UNIQUE_BEFORE_BACKUP
# both:        always merge both providers' pools together
BACKDROP_MODE=main-backup
BACKDROP_MIN_UNIQUE_BEFORE_BACKUP=3
# How many textless backdrops to keep in the pool per title. In
# "main-backup" mode this is one overall target. In "both" mode this
# applies PER PROVIDER (e.g. 6 = up to 6 from TMDB AND up to 6 from TVDB) -
# each provider is only dug into further if ITS OWN contribution loses
# candidates to dedup.
BACKDROP_POOL_TARGET_SIZE=6
# How many candidates to *request* from the provider API (before filtering)
BACKDROP_FETCH_LIMIT=20
# Seconds a single backdrop stays "active" before rotating to the next
BACKDROP_TTL_SECONDS=300
# Reject any backdrop whose width is below this fraction of the widest
# backdrop found in the same batch. 0.4 = reject anything under 40% of
# the max width - low enough that 1080p survives next to 4K (1920/3840 =
# 0.5), but 720p still gets dropped (1280/3840 = 0.33). Don't set this
# above 0.5 unless you specifically want to exclude 1080p whenever any
# 4K backdrop exists in the same batch.
BACKDROP_MIN_RELATIVE_WIDTH=0.4
# Hard floor regardless of the relative check
BACKDROP_MIN_ABSOLUTE_WIDTH=1280
# Perceptual-hash Hamming distance (0-64) below which two backdrops are
# considered duplicates. Lower = stricter (fewer false positives).
BACKDROP_DEDUP_HAMMING_THRESHOLD=8
# Second, independent similarity check (spatial color signature, 0-1,
# lower = stricter). A pair is only called a duplicate if BOTH this AND
# the pHash threshold above agree - reduces false-positive dedup of
# structurally-similar-but-different shots.
BACKDROP_DEDUP_COLOR_SIG_MAX_DISTANCE=0.12
# How often the background dedup/refill sweep runs per title, seconds
BACKDROP_REFRESH_INTERVAL_SECONDS=21600
